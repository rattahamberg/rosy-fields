# --- Neon Postgres (https://console.neon.tech) ---
# Pooled connection string — used at runtime through PgBouncer.
DATABASE_URL=postgresql://USER:PASSWORD@ep-XXXX-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require&channel_binding=require
# Unpooled connection string — used by drizzle-kit migrations.
# (Same as pooled but without "-pooler" in the host.)
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@ep-XXXX.REGION.aws.neon.tech/DBNAME?sslmode=require&channel_binding=require

# --- Better Auth ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET=
# Public origin of the deployment (no trailing slash).
BETTER_AUTH_URL=http://localhost:3000
